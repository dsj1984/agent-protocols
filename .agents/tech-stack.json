{
  "project": {
    "name": "[PROJECT_NAME]",
    "packageManager": "pnpm",
    "monorepoTool": "Turborepo"
  },
  "workspaces": {
    "web": "@repo/web",
    "mobile": "@repo/mobile",
    "api": "@repo/api",
    "shared": "@repo/shared"
  },
  "database": {
    "provider": "Turso",
    "dialect": "SQLite (libSQL)",
    "orm": "Drizzle ORM",
    "schemaPath": "packages/shared/src/db/schema.ts",
    "migrationCommand": "pnpm --filter @repo/shared db:generate"
  },
  "api": {
    "framework": "Hono",
    "runtime": "Cloudflare Workers",
    "routesPath": "apps/api/src/routes/",
    "validationLibrary": "Zod",
    "schemasPath": "packages/shared/src/schemas/index.ts"
  },
  "auth": {
    "provider": "Clerk",
    "middleware": "Clerk authentication middleware"
  },
  "frontend": {
    "web": {
      "framework": "Astro",
      "uiLibrary": "React (Islands)",
      "styling": "Tailwind CSS"
    },
    "mobile": {
      "framework": "Expo",
      "uiLibrary": "React Native",
      "router": "Expo Router"
    }
  },
  "testing": {
    "unitFramework": "Vitest",
    "e2eFramework": "Playwright",
    "testFilePattern": "*.test.ts"
  },
  "deployment": {
    "platform": "Cloudflare",
    "ci": "GitHub Actions"
  }
}
