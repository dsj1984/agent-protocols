{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Protocols — Unified Root Configuration",
  "agentSettings": {
    "baseBranch": "main",
    "agentRoot": ".agents",
    "scriptsRoot": ".agents/scripts",
    "workflowsRoot": ".agents/workflows",
    "personasRoot": ".agents/personas",
    "schemasRoot": ".agents/schemas",
    "docsRoot": "docs",
    "tempRoot": "temp",
    "auditOutputDir": "temp",
    "docsContextFiles": [
      "architecture.md",
      "data-dictionary.md",
      "decisions.md",
      "patterns.md",
      "style-guide.md",
      "web-routes.md"
    ],
    "release": {
      "docs": ["README.md"],
      "versionFile": null,
      "packageJson": true,
      "autoVersionBump": true
    },
    "sprintClose": {
      "runRetro": true
    },
    "maxInstructionSteps": 5,
    "maxTickets": 40,
    "maxTokenBudget": 200000,
    "executionTimeoutMs": 300000,
    "executionMaxBuffer": 10485760,
    "validationCommand": "pnpm turbo run lint typecheck",
    "lintBaselineCommand": "pnpm exec eslint . --format json",
    "lintBaselinePath": "temp/lint-baseline.json",
    "testCommand": "pnpm run test",
    "exploratoryTestCommand": "pnpm run test:exploratory",
    "typecheckCommand": "pnpm run typecheck",
    "buildCommand": "pnpm run build",
    "verboseLogging": {
      "enabled": false,
      "logDir": "temp/verbose-logs"
    },
    "frictionThresholds": {
      "repetitiveCommandCount": 3,
      "consecutiveErrorCount": 3,
      "stagnationStepCount": 5,
      "maxIntegrationRetries": 2
    },
    "riskGates": {
      "heuristics": [
        "Destructive or irreversible data mutations (dropping tables, deleting rows without soft-delete or backup, truncating production state).",
        "Modifications to shared security or auth infrastructure (IAM policies, auth middleware, session or token handling, secret rotation).",
        "Changes to CI/CD, deployment pipelines, or release gating that could disable safety checks or ship unverified code to production.",
        "Monorepo-wide AST or text replacements touching overlapping files in parallel (catastrophic merge-conflict risk across concurrent agents).",
        "Schema migrations that rewrite existing rows or drop columns without a backfill or rollback plan."
      ]
    }
  },
  "orchestration": {
    "provider": "github",
    "github": {
      "owner": "[OWNER]",
      "repo": "[REPO]",
      "projectNumber": null,
      "projectOwner": null,
      "operatorHandle": "@[USERNAME]"
    },
    "notifications": {
      "mentionOperator": true,
      "level": "verbose",
      "postToEpic": true,
      "webhookUrl": null
    },
    "hitl": {
      "riskHighApproval": true
    },
    "worktreeIsolation": {
      "enabled": true,
      "root": ".worktrees",
      "nodeModulesStrategy": "pnpm-store",
      "reapOnSuccess": true,
      "reapOnCancel": true,
      "warnOnUncommittedOnReap": true,
      "bootstrapFiles": [".env", ".mcp.json"]
    },
    "epicRunner": {
      "enabled": true,
      "concurrencyCap": 3,
      "pollIntervalSec": 30,
      "storyRetryCount": 1,
      "blockerTimeoutHours": 0,
      "notificationWebhookUrl": null
    }
  }
}
