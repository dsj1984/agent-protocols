{
  "name": "agent-protocols",
  "version": "5.12.4",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "node --test tests/*.test.js tests/lib/*.test.js tests/lib/worktree/*.test.js",
    "test:coverage": "node --experimental-test-coverage --test-coverage-exclude='.agents/scripts/bootstrap-agent-protocols.js' --test-coverage-exclude='.agents/scripts/context-hydrator.js' --test-coverage-exclude='.agents/scripts/dispatcher.js' --test-coverage-exclude='.agents/scripts/health-monitor.js' --test-coverage-exclude='.agents/scripts/notify.js' --test-coverage-exclude='.agents/scripts/ticket-decomposer.js' --test-coverage-exclude='.agents/scripts/mcp/run-audit-suite.js' --test-coverage-exclude='.agents/scripts/providers/github.js' --test --test-coverage-lines=85 --test-coverage-branches=70 --test-coverage-functions=75 tests/*.test.js tests/lib/*.test.js tests/lib/worktree/*.test.js",
    "mutate": "stryker run",
    "mutate:ci": "stryker run --reporters json,progress",
    "lint:md": "markdownlint \".agents/**/*.md\" \"*.md\" --ignore node_modules",
    "format:md": "prettier --write \".agents/**/*.md\" \"*.md\"",
    "lint": "biome lint . && markdownlint \".agents/**/*.md\" \"*.md\" --ignore node_modules",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "maintainability:check": "node .agents/scripts/check-maintainability.js",
    "maintainability:update": "node .agents/scripts/update-maintainability-baseline.js",
    "sync:commands": "node .agents/scripts/sync-claude-commands.js",
    "prepare": "husky && npm run sync:commands"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dsj1984/agent-protocols.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/dsj1984/agent-protocols/issues"
  },
  "homepage": "https://github.com/dsj1984/agent-protocols#readme",
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/tap-runner": "^9.6.0",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "markdownlint-cli": "^0.48.0",
    "memfs": "^4.57.1",
    "prettier": "^3.7.4"
  },
  "dependencies": {
    "string-argv": "^0.3.2",
    "typhonjs-escomplex": "^0.1.0"
  }
}
