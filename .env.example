# GitHub Authentication
# Required for ITicketingProvider and bootstrap scripts
# Fine-grained PAT or Classic PAT with 'repo' and 'project' (if applicable) scopes
GITHUB_TOKEN=your_github_pat_here

# LLM Provider API Keys
# At least one of these is required for the Epic Planner and PRD/Tech Spec generation
# Get Gemini API key at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Get Anthropic API key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Get OpenAI API key at: https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here
# (Optional) External Notification Webhook for HITL / Action-Required alerts
NOTIFICATION_WEBHOOK_URL=your_webhook_url_here
